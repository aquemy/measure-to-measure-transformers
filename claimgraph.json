    {
      "id": "leaf-barycenter-noncolinear",
      "kind": "conjecture",
      "statement": "L11: empirical measures in the orthant (geodesic hull modeled as cone(s) cap sphere) with disjoint geodesic hulls have non-colinear barycenters (not SameRay). Discharges review finding F2: the implication Prop 3.1's induction asserts without proof, for the empirical regime of Thm 1.1 and restricted Thm 1.2. General-measure case adds only 'barycenter in closed convex hull of support'.",
      "status": "math.machine-checked",
      "effective_status": "math.machine-checked",
      "in_question": false,
      "weakest_dep": null
    },
    {
      "id": "leaf-barycenter-noncolinear-general",
      "kind": "conjecture",
      "statement": "L11': finding F2 for arbitrary probability measures. Two probability measures supported in disjoint closed convex cones have non-colinear (not SameRay) barycenters, via Mathlib's Convex.integral_mem (barycenter in any closed convex set carrying full mass). Closes the general-measure residual of F2 with no new axioms.",
      "status": "math.machine-checked",
      "effective_status": "math.machine-checked",
      "in_question": false,
      "weakest_dep": null
    },
