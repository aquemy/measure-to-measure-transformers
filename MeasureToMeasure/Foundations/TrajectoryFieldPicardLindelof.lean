import MeasureToMeasure.Foundations.AttnFieldTrajectoryContinuous
import Mathlib.Analysis.ODE.PicardLindelof
import Mathlib.Analysis.ODE.ExistUnique

/-!
# Picard-Lindelöf for the field composed with a candidate trajectory (M3b existence, leaf E3e)

Assembles the two ingredients banked in leaves E3c/E3d into a genuine instance of Mathlib's
*time-dependent* `IsPicardLindelof` for the field evaluated along a candidate measure trajectory
`η : C([0,T], SphereProb d)`, mirroring `Block.isPicardLindelof`'s pattern for the time-independent
case but with `trajectoryField p hT η t x := attnFieldExt p (η (projIcc 0 T hT t)).val x` in place of
the frozen `b.field`:

* Lipschitz-in-`x`, uniformly in `t` — inherited unchanged from `attnFieldExt_lipschitz` (leaf
  E2a-4), since it holds for *every* sphere-supported probability measure, not just a frozen one;
* continuous-in-`t`, at every `x` — leaf E3d's `continuous_attnFieldExt_comp_trajectory`, composed
  with the continuous domain-extension `Set.projIcc`;
* the uniform bound and the size bookkeeping (`mul_max_le`) — the same `5·fieldBallBound p` constant
  as the frozen case (`norm_attnFieldExt_le`), so the same `a = 5·fieldBallBound p · T + r` works.

This gives, via Mathlib's `exists_eq_forall_mem_Icc_hasDerivWithinAt`, a genuine local integral curve
of `ẋ = attnFieldExt p (η t) x` through any starting point — the **inner** Picard step for a
*trial* trajectory `η`, exactly analogous to what `frozenFlow`/`Block.exists_integralCurveOn` give
for a single frozen measure. The **outer** step (E3+) will evaluate this at `η = ` the trajectory of
pushforward measures generated by iterating this very map, and needs a fixed point of that
self-consistency map in the Bielecki metric (leaves E3a/E3b).

M3b staging: consumed when `exists_meanFieldFlow` is discharged; see RESEARCH.md.
-/

open MeasureTheory Set Filter Topology
open scoped NNReal

namespace MeasureToMeasure.Foundations

variable {d : ℕ}

/-- The field evaluated along a candidate measure trajectory `η`, with time reindexed into `[0,T]`
via `Set.projIcc` (junk-free: `η`'s domain already is `[0,T]`, and `projIcc` is the identity there).
-/
noncomputable def trajectoryField (p : AttnParams d) {T : ℝ} (hT : 0 ≤ T)
    (η : C(Set.Icc (0 : ℝ) T, SphereProb d)) : ℝ → Eucl d → Eucl d :=
  fun t x => attnFieldExt p (η (Set.projIcc 0 T hT t)).val x

/-- **The trajectory field satisfies Mathlib's time-dependent Picard-Lindelöf hypotheses**, with the
same size constants as the frozen (time-independent) case: bound `5·fieldBallBound p`, Lipschitz
constant `5·fieldBallLip p + 4·fieldBallBound p + 5·fieldBallBound p`. -/
theorem trajectoryField_isPicardLindelof (p : AttnParams d) {T : ℝ} (hT : 0 ≤ T)
    (η : C(Set.Icc (0 : ℝ) T, SphereProb d)) (x₀ : Eucl d) (r : ℝ≥0) :
    IsPicardLindelof (trajectoryField p hT η) (tmin := (0 : ℝ)) (tmax := T)
      ⟨0, Set.mem_Icc.mpr ⟨le_refl 0, hT⟩⟩
      x₀ (5 * fieldBallBound p * T + r).toNNReal r (5 * fieldBallBound p).toNNReal
      (Real.toNNReal (5 * fieldBallLip p + 4 * fieldBallBound p)
        + Real.toNNReal (5 * fieldBallBound p)) where
  lipschitzOnWith := fun t _ => by
    haveI := (η (Set.projIcc 0 T hT t)).property.1
    exact (attnFieldExt_lipschitz p (η (Set.projIcc 0 T hT t)).val
      (η (Set.projIcc 0 T hT t)).property.2).lipschitzOnWith
  continuousOn := by
    intro x _
    have hcont := continuous_attnFieldExt_comp_trajectory p η x
    have hproj : Continuous (Set.projIcc 0 T hT (α := ℝ)) := continuous_projIcc
    exact (hcont.comp hproj).continuousOn
  norm_le := fun t _ x _ => by
    haveI := (η (Set.projIcc 0 T hT t)).property.1
    have h := norm_attnFieldExt_le p (η (Set.projIcc 0 T hT t)).val
      (η (Set.projIcc 0 T hT t)).property.2 x
    rw [Real.coe_toNNReal _ (five_bound_nonneg p)]
    exact h
  mul_max_le := by
    have h0 : (0 : ℝ) ≤ 5 * fieldBallBound p := five_bound_nonneg p
    have hLcoe : ((5 * fieldBallBound p).toNNReal : ℝ) = 5 * fieldBallBound p :=
      Real.coe_toNNReal _ h0
    have hmax : max ((T : ℝ) - 0) (0 - 0) = T := by simp [hT]
    have h1 : (0 : ℝ) ≤ 5 * fieldBallBound p * T := mul_nonneg h0 hT
    have h2 : (0 : ℝ) ≤ (r : ℝ) := r.coe_nonneg
    have harg : (0 : ℝ) ≤ 5 * fieldBallBound p * T + r := by linarith
    have hacoe : ((5 * fieldBallBound p * T + r).toNNReal : ℝ) = 5 * fieldBallBound p * T + r :=
      Real.coe_toNNReal _ harg
    rw [hmax, hLcoe, hacoe]
    nlinarith [h1, h2]

/-- **Local existence for the trajectory-composed characteristic ODE.** For any candidate measure
trajectory `η` and starting point `x₀`, there is an integral curve of `ẋ = attnFieldExt p (η t) x`
on `[0,T]` with `α 0 = x₀`. The inner Picard step for a *trial* `η`; mirrors
`Block.exists_integralCurveOn` for the frozen case. -/
theorem exists_trajectoryField_integralCurveOn (p : AttnParams d) {T : ℝ} (hT : 0 ≤ T)
    (η : C(Set.Icc (0 : ℝ) T, SphereProb d)) (x₀ : Eucl d) :
    ∃ α : ℝ → Eucl d, α 0 = x₀ ∧
      ∀ t ∈ Set.Icc (0 : ℝ) T, HasDerivWithinAt α (trajectoryField p hT η t (α t))
        (Set.Icc (0 : ℝ) T) t := by
  have hx : x₀ ∈ Metric.closedBall x₀ ((0 : ℝ≥0) : ℝ) := by simp
  obtain ⟨α, hα0, hαderiv⟩ :=
    (trajectoryField_isPicardLindelof p hT η x₀ 0).exists_eq_forall_mem_Icc_hasDerivWithinAt hx
  exact ⟨α, hα0, hαderiv⟩

end MeasureToMeasure.Foundations
